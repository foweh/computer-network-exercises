	}
}


function lockSubmit(lock){
	if(lock){
	    window.submitOnce = true;
		$('body').css({'pointer-events': 'none'});
	}else{
		window.submitOnce = false;
        $('body').css({'pointer-events': 'auto'});
	}
}

