function escapeHTML(str) {
	return str.replace(/[&<">']/g, function (a, b) {
		return {
			'<': '&lt;',
			'&': '&amp;',
			'"': '&quot;',
			'>': '&gt;',
			"'": '&#39;'
		}[a];
	});
}

