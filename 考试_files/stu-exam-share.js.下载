var terminalUnlockClickFlag = false;

function terminalUnlockAction() {
	var courseId = $('#courseId').val();
	var classId = $('#classId').val();
	var personId = $('#cpi').val();
	var examRelationId = $('#testPaperId').val();
	var answerId = $('#testUserRelationId').val();
	var code = '';
	$('#deviceLockPopMask .passwordBox input').each(function () {
		var num = $(this).attr('data-value') || '';
		code += num;
	});
	if (code == '') {
		$.toast({type: 'notice', content: '请输入口令码'});
		return
	}
	if (terminalUnlockClickFlag) {
		return;
	}
	terminalUnlockClickFlag = true;
	setTimeout(function () {
		terminalUnlockClickFlag = false;
	}, 2000);
	var examAnswerPage = $('#examAnswerPage').val() || 0;
	var winId = 'deviceLockPopMask';
	var url = _HOST_CP2_ + '/mooc2/exam/terminal-unlock?courseId=' + courseId + '&classId=' + classId
		+ '&cpi=' + personId + '&examId=' + examRelationId + '&answerId=' + answerId + '&code=' + code;
	$.ajax({
		type: 'post',
		dataType: 'json',
		url: url,
		success: function (result) {
			if (!result.status) {
				$.toast({type: 'failure', content: result.msg});
				return
			}
			$.toast({type: 'success', content: '解锁成功，请继续作答'});
			terminalUnlockLog();
			setTimeout(function () {
				if (examAnswerPage != 1) {
					var url = location.href;
					if (url.indexOf("&_v=") == -1) {
						url += "&_v=" + Math.random();
					} else {
						url = url.replace(/&_v=[^&]*/, "&_v=" + Math.random());
					}
					location.href = url;
				} else {
					$("#" + winId).hide();
				}
			}, 1500);
		},
		error: function () {
			//$.toast({type: 'failure', content: '网络异常，请重试'});
		}
	});
}


