function unhtml(input) {
    if(!input || input.length == 0) {
        return input;
    }
    var newInput=input.replace(/[&<">']/g, function (a, b) {
        return {
            '<':'&lt;',
            '&':'&amp;',
            '"':'&quot;',
            '>':'&gt;',
            "'":'&#39;'
        }[a];
    }) ;
    return newInput;
}

