function groupPaperLimitTimeNextCheck(n, targetGroupId) {
	var groupLimitTimeType = $("#groupLimitTimeType").val() || 0;
	var forbidGroupAnswerBack = $("#forbidGroupAnswerBack").val() || 0;
	if (groupLimitTimeType > 0 || forbidGroupAnswerBack > 0) {
		var thisQuestionGroupId = $("#thisQuestionGroupId").val() || 0;
		if (targetGroupId == thisQuestionGroupId) {
			return false;
		}
		var nextGroupPaperId = $("#nextGroupPaperId").val() || 0;
		var checkGroupPop = $("#checkGroupPop").val() || 0;
		if (nextGroupPaperId == targetGroupId) {
			$("#groupStart").val(n)
			groupPaperLimitTimePopShow("groupPaperLimitTimePop");
		}
		return checkGroupPop == 0;
	}
	return false;
}

function groupPaperLimitTimePopShow(popId) {
