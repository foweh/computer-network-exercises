var SingleQuesLimitTime;
function checkStartSingleQuesLimitTimeTimer() {
	var limitTimeType = $('#limitTimeType').val() || 0;
	if(limitTimeType == 0){
		return;
	}
	SingleQuesLimitTime =  loadSingleQuesLimitTime();
	if(SingleQuesLimitTime < 0){
		SingleQuesLimitTime = $('#singleQuesLimitTime').val();
	}
	if (SingleQuesLimitTime >= 0) {
		var clockTime = secondsToClockTime();
		$(".singleQuesLimitTimeClock").html(clockTime);
		singleTimerHandle = setInterval("singleQuesLimitTimeTimer()", 1000);
	}
}

var groupPaperLimitTime;
var groupLimitTimeTimer;
function checkStartGroupPaperLimitTimeTimer() {
	var groupLimitTimeType = $('#groupLimitTimeType').val() || 0;
	if(groupLimitTimeType == 0){
		return;
	}
	groupPaperLimitTime = calculationStartGroupTime();
	if(groupPaperLimitTime < 0){
		// groupPaperLimitTime = $('#groupMaxLimitTime').val();
		groupPaperLimitTime = 0;
	}
	if (groupPaperLimitTime >= 0) {
		var clockTime = secondsToClockTimeByLimit(groupPaperLimitTime);
		$(".groupPaperLimitTimeClock").html(clockTime);
		groupLimitTimeTimer = setInterval("groupPaperLimitTimeTimer()", 1000);
	}
}


function calculationStartGroupTime() {
	var groupMaxLimitTime = $('#groupMaxLimitTime').val();
	var groupReceiveTime = $('#groupReceiveTime').val();
	groupReceiveTime = Math.floor(groupReceiveTime / 1000);
	var timestamp = new Date().getTime();
	timestamp = Math.floor(timestamp / 1000);
	var startTime = timestamp - groupReceiveTime;
	return groupMaxLimitTime - startTime;
}

function secondsToClockTime(){
	var minutes = '00';
	var seconds = '00';
	var clockTime = minutes + ':' + seconds ;
	if (SingleQuesLimitTime > 0) {
	    minutes = Math.floor(SingleQuesLimitTime / 60);
		if (minutes < 10) {
			minutes = "0" + minutes;
		}
		seconds = Math.floor(SingleQuesLimitTime % 60);
		if (seconds < 10) {
			seconds = "0" + seconds;
		}
		clockTime = minutes + ':' + seconds ;
	}
	return clockTime;
}

function secondsToClockTimeByLimit(limitTime){
	var minutes = '00';
	var seconds = '00';
	var clockTime = minutes + ':' + seconds;
	if (limitTime > 0) {
		minutes = Math.floor(limitTime / 60);
		if (minutes < 10) {
			minutes = "0" + minutes;
		}
		seconds = Math.floor(limitTime % 60);
		if (seconds < 10) {
			seconds = "0" + seconds;
		}
		clockTime = minutes + ':' + seconds;
	}
	return clockTime;
}

function singleQuesLimitTimeTimer() {
	var clockTime = secondsToClockTime();
	$(".singleQuesLimitTimeClock").html(clockTime);
	$("#singleQuesLimitTime").val(SingleQuesLimitTime);
	storeSingleQuesLimitTime(SingleQuesLimitTime);
	if (SingleQuesLimitTime > 0) {
		--SingleQuesLimitTime;
	} else {
		clearInterval(singleTimerHandle);
		$('#singleQuesLimitTimePop').fullFadeIn();
	}
}

function groupPaperLimitTimeTimer() {
	var clockTime = secondsToClockTimeByLimit(groupPaperLimitTime);
	$(".groupPaperLimitTimeClock").html(clockTime);
	var groupMinLimitTime = $("#groupMinLimitTime").val() || 0;
	if (groupMinLimitTime > 0) {
		$("#groupMinLimitTime").val(groupPaperLimitTime);
	}
	$("#groupMaxLimitTime").val(groupPaperLimitTime);
	if (groupPaperLimitTime > 0) {
		--groupPaperLimitTime;
	} else {
		clearInterval(groupLimitTimeTimer);
		groupPaperLimitTimePopShow("groupPaperLimitTimeOverPop");
	}
}

function storeSingleQuesLimitTime(seconds){
	if(!window.sessionStorage){
		return;
	}
	if(sessionStorage.length > 0){
