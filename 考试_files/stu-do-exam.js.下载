$(function () {
	var questionWrap = $('#submitTest');
	var quesId = questionWrap.find('input[name="questionId"]').val();
	var fillinblankType = questionWrap.find('input[name="type' + quesId + '"]').val();
	if (fillinblankType == 24) {
		getFillinBlanksData();
		var fillinBlanksContent = $('.fillBlanksChoose');
		var fillinBlanksSource;
		fillinBlanksContent.on("dragstart", function (e) {
			fillinBlanksSource = e.target
		});

		fillinBlanksContent.on("dragover", function (e) {
			e.preventDefault();
		});

		fillinBlanksContent.on("dragenter", function (e){
			var dropNode = getFillinBlanksNode(e.target)
			clearFillinBlanksStyle()
			if (dropNode && dropNode.dataset.drop === 'copy') {
				dropNode.classList.add('drop-over')
			}
		});

		fillinBlanksContent.on("drop", function (e) {
			var dropNode = getFillinBlanksNode(e.target)
			clearFillinBlanksStyle()
			if (dropNode && dropNode.dataset.drop === 'copy') {
				var sourceValue = fillinBlanksSource.childNodes[0].nodeValue;
				sourceValue = sourceValue.replace(/[&<">']/g, function(a, b) {
					return {
						'<' : '&lt;',
						'&' : '&amp;',
						'"' : '&quot;',
						'>' : '&gt;',
						"'" : '&#39;'
					}[a];
				});
				dropNode.innerHTML = sourceValue;
				dropNode.classList.add('hasFill');
				dropNode.dataset.chooseName = fillinBlanksSource.dataset.chooseName;
				dropNode.draggable = true;
			}

			if (fillinBlanksSource && fillinBlanksSource.dataset.drop == 'copy' && fillinBlanksSource !== dropNode) {
				fillinBlanksSource.innerHTML = '';
				fillinBlanksSource.classList.remove('hasFill');
				fillinBlanksSource.dataset.chooseName = "";
				fillinBlanksSource.draggable = false
			}
			getFillinBlanksData()
		});
	}
})

function getFillinBlanksData() {
	var fillBlankList = [];
	var fillBlanks = [];
	for (var index = 0; index < $('.textTarget').length; index++) {
		var ele = $('.textTarget')[index];
		fillBlankList.push(ele.innerText)
		var content = "";
		if (typeof (ele.dataset.chooseName) != "undefined") {
			content = ele.dataset.chooseName;
		}
		var fillBlank = { "name" : index + 1,"content": content };
		fillBlanks.push(fillBlank);
	}

	for (var i = 0; i < $('.blanksBox span').length; i++) {
		var e = $('.blanksBox span')[i];
		var count = 0;
		fillBlankList.forEach(function (item) {
			if (item.trim() == e.childNodes[0].nodeValue.trim()) {
				count++
			}
		})

		var dropNodeVal = e.childNodes[0].nodeValue;
		if (count == 0) {
			e.innerText = dropNodeVal;
		} else {
			e.innerText = dropNodeVal;
			var iEle = document.createElement("i");
			iEle.innerText = count;
			e.appendChild(iEle);
		}
	}
	var questionId = $("#questionId").val();
	var answerStr=JSON.stringify(fillBlanks);
	$("#answer" + questionId).val(answerStr)

}

