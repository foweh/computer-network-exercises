function checkGroupPaperLimitTimeRemainTime(){
	var groupLimitTimeType = $('#groupLimitTimeType').val() || 0;
	if(groupLimitTimeType == 0){
		return;
	}

	var leaveTime = window.Leave_Exam_Page || -1;
	var backTime = window.Back_Exam_Page || -1 ;
	if (leaveTime <=0 || backTime <= 0) {
		return;
	}

	var groupLimitTime = window.Leave_groupPaperLimitTime || -1;
	if (groupLimitTime < 0) {
		return;
	}

	var diffMillSeconds = parseInt(backTime) - parseInt(leaveTime);
	var useSeconds = Math.ceil((diffMillSeconds / 1000).toFixed(3));
	if(useSeconds <= 0){
		return
	}

	var remainSeconds = parseInt(groupLimitTime) - parseInt(useSeconds);
	if(remainSeconds <= 0){
		remainSeconds  = 1;
	}
