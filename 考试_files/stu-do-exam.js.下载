function addChoice(obj) {
    var subObj = $(obj).find(".addChoice");
    var qid = $(subObj).attr("qid");

    if($(subObj).hasClass("check_answer")) {
        $(subObj).removeClass("check_answer");
    } else {
        $(".choice" + qid).removeClass("check_answer");
        $(subObj).addClass("check_answer");
    }

    var choiceContent = "";
    $(".choice" + qid).each(function(index,ele){
        if($(this).hasClass("check_answer")){
            choiceContent = choiceContent + $(this).attr("data");
        }
    });

    $("#answer" + qid).val(choiceContent);
}

// 无障碍定制单选
function tabAddChoice(obj) {
	var subObj = $(obj).find(".addChoice");
	var qid = $(subObj).attr("qid");
	if (event.keyCode == 13) {
		event.preventDefault(); // 阻止默认的键盘点击事件
		if($(subObj).hasClass("check_answer")) {
			$(subObj).removeClass("check_answer");
		} else {
			$(".choice" + qid).removeClass("check_answer");
			$(subObj).addClass("check_answer");
			$(subObj).parent().attr("aria-checked","true");
			$(subObj).parent().attr("aria-pressed","true");
		}

		var choiceContent = "";
		$(".choice" + qid).each(function(index,ele){
			if($(this).hasClass("check_answer")){
				choiceContent = choiceContent + $(this).attr("data");
			} else {
				$(this).parent().attr("aria-checked","false");
				$(this).parent().attr("aria-pressed","false");
			}
		});

		$("#answer" + qid).val(choiceContent);
	} else if (event.keyCode == 32) { // 空格选中
		event.preventDefault(); // 阻止默认的键盘点击事件
		$(".choice" + qid).removeClass("check_answer");
		$(subObj).addClass("check_answer");

		var choiceContent = "";
		$(".choice" + qid).each(function(index,ele){
			if($(this).hasClass("check_answer")){
				choiceContent = choiceContent + $(this).attr("data");
				$(this).parent(".answerBg").attr("aria-checked","true");
				$(this).parent(".answerBg").attr("aria-pressed","true");
			} else {
				$(this).parent(".answerBg").attr("aria-checked","false");
				$(this).parent(".answerBg").attr("aria-pressed","false");
			}
		});

		$("#answer" + qid).val(choiceContent);
	}
}
// 无障碍定制多选
function tabAddMultipleChoice(obj) {
	if (event.keyCode == 13 || event.keyCode == 32) {
		event.preventDefault(); // 阻止默认的键盘点击事件
		var subObj = $(obj).find(".addMultipleChoice");
		var qid = $(subObj).attr("qid");

		if($(subObj).hasClass("check_answer_dx")) {
			$(subObj).removeClass("check_answer_dx");
			$(obj).attr("aria-checked","false");
			$(obj).attr("aria-pressed","false");
		} else {
			$(subObj).addClass("check_answer_dx");
			$(obj).attr("aria-checked","true");
			$(obj).attr("aria-pressed","true");
		}

		var choiceContent = "";
		$(".choice" + qid).each(function(){
			if($(this).hasClass("check_answer_dx")){
				choiceContent = choiceContent + $(this).attr("data");
			}
		});
		$("#answer" + qid).val(choiceContent);
	}
}

function addChoiceByBType(obj) {
    var qid = $(obj).attr("qid");
    var parentDiv = $(obj).parent();

    if($(obj).hasClass("check_answer")) {
        $(obj).removeClass("check_answer");
    } else {
        parentDiv.find(".choice" + qid).removeClass("check_answer");
        $(obj).addClass("check_answer");
    }

    var answerPair=[];
    $(".BType_"+qid).each(function () {
        var name = $(this).attr("index");
        var contentStr = "";
        $(this).find(".choice" + qid).each(function(){
            if($(this).hasClass("check_answer")){
                contentStr = $(this).attr("choice_name");
                return false;
            }
        });

        var obj={};
        obj.name = parseInt(name);
        obj.content = contentStr;
        answerPair.push(obj);
    });

    var answerStr=JSON.stringify(answerPair);
    $("#answer" + qid).val(answerStr);
}

function addMultipleChoice(obj) {
    var subObj = $(obj).find(".addMultipleChoice");
    var qid = $(subObj).attr("qid");

    if($(subObj).hasClass("check_answer_dx")) {
        $(subObj).removeClass("check_answer_dx");
    } else {
        $(subObj).addClass("check_answer_dx");
    }

    var choiceContent = "";
    $(".choice" + qid).each(function(){
        if($(this).hasClass("check_answer_dx")){
            choiceContent = choiceContent + $(this).attr("data");
        }
    });
    $("#answer" + qid).val(choiceContent);
}

